set default-bg              "#ebeef3"
set default-fg              "#181c20"

set statusbar-bg            "#dde3ea"
set statusbar-fg            "#41474d"

set inputbar-bg             "#dde3ea"
set inputbar-fg             "#41474d"

set notification-bg         "#e0e3e8"
set notification-fg         "#181c20"
set notification-warning-bg "#ebdcff"
set notification-warning-fg "#211634"
set notification-error-bg   "#ffdad6"
set notification-error-fg   "#410002"

set highlight-color         "rgba(235, 220, 255, 0.5)"
set highlight-active-color  "rgba(101, 88, 123, 0.5)"

set completion-bg           "#ebeef3"
set completion-fg           "#181c20"
set completion-highlight-bg "#29638a"
set completion-highlight-fg "#ffffff"

set recolor                 "true"
set recolor-keephue         "true"
set recolor-reverse-video   "true"

set recolor-lightcolor      "#f7f9ff"
set recolor-darkcolor       "#181c20"

set selection-clipboard     "clipboard"

set incremental-search      "true"
set search-hadjust          "true"

set adjust-open             "width"

set page-padding            8

set guioptions              ""

set smooth-scroll           "true"
set scroll-step             50

map [normal]     b toggle_statusbar
map [fullscreen] b toggle_statusbar

map [normal]     i set recolor
map [fullscreen] i set recolor
