  "route": {
    "default_http_client": "proxy",
    "default_domain_resolver": {
      "server": "domestic",
      "strategy": "prefer_ipv6",
      "disable_optimistic_cache": true
    },
    "rules": [
      {
        "action": "sniff"
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "ip_is_private": true,
        "outbound": "🟢 DIRECT"
      },
      {
        "action": "route",
        "rule_set": ["private_domain", "fakeip_filter"],
        "outbound": "🟢 DIRECT"
      },
      {
        "action": "route",
        "rule_set": [
          "qiufen_ad_doamin",
          "category_ads_domain",
          "category_porn_domain",
          "blacklist"
        ],
        "outbound": "🔴 BLOCK"
      },
      {
        "action": "route",
        "rule_set": ["direct_apps"],
        "outbound": "🟢 DIRECT"
      },
      {
        "action": "route",
        "clash_mode": "direct",
        "outbound": "🟢 DIRECT"
      },
      {
        "action": "route",
        "clash_mode": "global",
        "outbound": "🪐 GLOBAL"
      },
      {
        "action": "route",
