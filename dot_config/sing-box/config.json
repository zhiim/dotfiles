  "log": {
    "disabled": false,
    "level": "info",
    "output": "sing-box.log",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      },
      {
        "tag": "hosts",
        "type": "hosts",
        "predefined": {
          "dns.alidns.com": ["223.5.5.5", "223.6.6.6"],
          "dns.google": ["8.8.8.8", "8.8.4.4"]
        }
      },
      {
        "tag": "domestic",
        "type": "https",
        "server": "dns.alidns.com",
        "server_port": 443,
        "path": "/dns-query",
        "domain_resolver": "hosts"
      },
      {
        "tag": "foreign",
        "type": "https",
        "server": "dns.google",
        "server_port": 443,
        "path": "/dns-query",
        "domain_resolver": "hosts",
        "detour": "🥤 默认"
      }
    ],
    "rules": [
      {
        "query_type": ["HTTPS", "SVCB"],
        "action": "predefined",
        "rcode": "NOERROR"
      },
      {
        "rule_set": [
          "qiufen_ad_doamin",
          "category_ads_domain",
          "category_porn_domain",
          "blacklist"
        ],
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      {
        "action": "evaluate",
        "server": "hosts"
      },
      {
        "match_response": true,
        "ip_accept_any": true,
        "action": "respond"
      },
      {
        "rule_set": ["private_domain", "fakeip_filter"],
        "action": "route",
        "server": "domestic"
      },
      {
        "rule_set": ["direct_apps"],
        "action": "route",
        "server": "domestic"
      },
      {
        "clash_mode": "direct",
        "action": "route",
        "server": "domestic"
      },
      {
        "clash_mode": "global",
        "query_type": ["A", "AAAA"],
        "action": "route",
        "server": "fakeip",
        "rewrite_ttl": 1
      },
      {
        "clash_mode": "global",
        "action": "route",
        "server": "foreign"
      },
      {
        "rule_set": ["google_domain", "geolocation-!cn"],
        "query_type": ["A", "AAAA"],
        "action": "route",
        "server": "fakeip",
        "rewrite_ttl": 1
      },
      {
        "rule_set": ["cn_domain"],
        "action": "route",
        "server": "domestic"
      },
      {
        "action": "evaluate",
        "server": "foreign",
        "client_subnet": "114.114.114.114/24"
      },
      {
        "match_response": true,
        "ip_accept_any": true,
        "invert": true,
        "action": "respond"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "match_response": true, "ip_is_private": true },
          { "match_response": true, "rule_set": "cn_ip" }
        ],
        "action": "route",
        "server": "domestic"
      },
      {
        "query_type": ["A", "AAAA"],
        "action": "route",
        "server": "fakeip",
        "rewrite_ttl": 1
      }
    ],
    "final": "foreign",
    "optimistic": {
      "enabled": true,
      "timeout": "1d"
    }
  },
