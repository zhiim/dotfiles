        "update_interval": "24h"
      },
      {
        "tag": "blacklist",
        "type": "remote",
        "url": "https://raw.githubusercontent.com/zhiim/dotfiles/master/dot_config/sing-box/rule_set/blacklist.srs",
        "format": "binary",
        "update_interval": "24h"
      },
      {
        "tag": "direct_apps",
        "type": "inline",
        "rules": [
          {
            "process_path": [
              "/usr/bin/linuxqq",
              "/opt/wechat/wechat",
              "/usr/bin/krdc"
            ]
          },
          {
            "process_path_regex": ["/tmp/\\.mount_linux.*/qq", "/opt/wechat/.*"]
          },
          {
            "package_name": ["com.tencent.mm", "com.tencent.mobileqq"]
          }
        ]
      }
    ],
    "auto_detect_interface": true,
    "final": "🐟 漏网之鱼"
