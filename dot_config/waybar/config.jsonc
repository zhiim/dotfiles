{
    "include": [
        "~/.config/waybar/modules.jsonc"
    ],
    "layer":"top",
    "position": "top",
    "fixed-center": true,
    "reload_style_on_change": true,
    "modules-left": [
        "custom/applauncher",
        "custom/screenshot",
        "mpris",
	"custom/clipboard",
        "niri/window",
        "network#speed"
    ],
    "modules-center": [
        "niri/workspaces",
    ],
    "modules-right": [
        "tray",
        "cpu",
        "memory",
        "group/backlight",
        "group/audio",
        "bluetooth",
        "network",
        "battery",
        "power-profiles-daemon",
        "clock",
        "group/powermenu"
    ],
}
