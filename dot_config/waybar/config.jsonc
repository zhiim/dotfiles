{
    "include": [
        "~/.config/waybar/modules.jsonc"
    ],
    "layer":"top",
    "position": "top",
    "height": 36,
    "fixed-center": true,
    "reload_style_on_change": true,
    "modules-left": [
        "custom/applauncher",
        "niri/window",
        "network#speed"
    ],
    "modules-center": [
        "niri/workspaces",
    ],
    "modules-right": [
        "tray",
        "custom/notification",
	"custom/clipboard",
        "group/screen",
        "group/audio",
        "bluetooth",
        "network",
        "group/performance",
        "clock",
        "group/powermenu"
    ],
}
