{
  "custom/applauncher": {
    "tooltip-format": "е·¦й”®пәљиҢҮд»¶еђҮеЉЁиЏњеҚ•\nеЏій”®пәљж‰“еәЂз»€з«Ү",
    "format": "пЊѓ",
    "on-click": "rofi -show drun",
