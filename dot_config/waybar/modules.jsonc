    ],
  },
  "custom/wlogout": {
    "tooltip-format": "е·¦й”®пәље…іжњғ",
    "format": "пЂ‘",
    "on-click": "choice=$(echo -e 'пЂҚ\\nпЂЊ' | rofi -dmenu -i -p 'зҰ®е®љи¦Ѓе…іжњғеђ—пәџ ' -theme '~/.config/rofi/theme/confirm.rasi'); [ \"$choice\" = 'пЂЊ' ] && notify-send 'е…іжњғдё­...' && systemctl poweroff",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "custom/reboot": {
    "tooltip-format": "е·¦й”®пәљй‡ҚеђҮ",
    "format": "пЂһ",
    "on-click": "choice=$(echo -e 'пЂҚ\\nпЂЊ' | rofi -dmenu -i -p 'зҰ®е®љи¦Ѓй‡ҚеђҮеђ—пәџ ' -theme '~/.config/rofi/theme/confirm.rasi'); [ \"$choice\" = 'пЂЊ' ] && notify-send 'й‡ҚеђҮдё­...' && systemctl reboot",
    "on-scroll-up": "true",
    "on-scroll-down": "true"
  },
  "custom/logout": {
    "tooltip-format": "е·¦й”®пәљз™»е‡ғ",
    "format": "п‚‹",
