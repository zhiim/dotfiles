      },
    },
    "max-length": 25,
    "on-click": "wezterm --config enable_tab_bar=false start --always-new-process --class calcure -- calcure",
  },
  "group/powermenu": {
    "orientation": "inherit",
    "drawer": {
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/wlogout",
      "custom/reboot",
