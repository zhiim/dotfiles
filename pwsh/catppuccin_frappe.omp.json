{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "foreground": "p:foreground",
          "background": "p:main_color1",
          "leading_diamond": "\ue0b6",
          "template": " {{ if .SSHSession }}\ueba9 {{ end }}{{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:black",
          "background": "p:main_color2",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "folder"
          }
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:black",
          "background": "p:other",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:black",
          "background": "p:green",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:red{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:yellow{{ end }}",
            "{{ if gt .Ahead 0 }}p:attention{{ end }}",
            "{{ if gt .Behind 0 }}p:attention{{ end }}"
          ],
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Staging.Changed) (.Working.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} ",
          "properties": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "status",
          "style": "diamond",
          "leading_diamond": "<transparent,background>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "foreground": "p:black",
          "background": "p:green",
          "background_templates": ["{{ if gt .Code 0 }}p:red{{ end }}"],
          "template": " {{ if gt .Code 0 }}\uf467 {{ reason .Code }}{{ else }}\uf42e {{ end }}",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right"
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:white",
          "template": "\u276f "
        }
      ],
      "newline": true
    }
  ],
  "palette": {
    "attention": "#f0c6c6",
    "black": "#303446",
    "foreground": "#303446",
    "green": "#a6d189",
    "main_color1": "#ca9ee6",
    "main_color2": "#f4b8e4",
    "other": "#8caaee",
    "red": "#e78284",
    "text": "#c6d0f5",
    "yellow": "#e5c890"
  }
}
